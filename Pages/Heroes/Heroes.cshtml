@page
@model HeroEngine.Pages.Heroes.HeroesModel
@{
	ViewData["Title"] = "Heroes";
}

<div class="text-center">
	<h1 class="display-4">Hero Engine</h1>
	<p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>
<h1>List of heroes</h1>
<a asp-page="/Heroes/Create" class="btn btn-primary">Create hero</a>
<table>
	<thead>
		<tr>
			<th>Id</th>
			<th>Name</th>
			<th>Class</th>
			<th>Level</th>
			<th>Hp</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var hero in Model.Party)
		{
			<tr>
				<td>@hero.Id</td>
				<td>@hero.Name</td>
				<td>@hero.GetType().Name</td>
				<td>@hero.Level</td>
				<td>@hero.Hp</td>
			</tr>
		}
	</tbody>
</table>